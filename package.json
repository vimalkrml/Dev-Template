{
  "name": "@datafluxgrid/fluxgrid-css",
  "version": "1.0.22",
  "description": "Utility-first CSS framework with zero build step. No CLI, no PostCSS, no config — just drop in one CSS file and use utility classes. Includes dark mode, design tokens, animations, and form styles built in.",
  "main": "src/index.css",
  "style": "src/index.css",
  "exports": {
    ".": "./src/index.css",
    "./*": "./src/*"
  },
  "files": [
    "src"
  ],
  "keywords": [
    "css",
    "css-framework",
    "utility-first",
    "utility-css",
    "atomic-css",
    "css-utilities",
    "no-build",
    "zero-config",
    "no-postcss",
    "vanilla-css",
    "pure-css",
    "lightweight-css",
    "design-tokens",
    "design-system",
    "css-variables",
    "dark-mode",
    "responsive-design",
    "flexbox",
    "css-grid",
    "animations",
    "forms",
    "tailwind-alternative",
    "bootstrap-alternative",
    "frontend",
    "fluxgrid",
    "datafluxgrid"
  ],
  "homepage": "https://fluxgrid-css.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vimalkrml/fluxgrid-css.git"
  },
  "bugs": {
    "url": "https://github.com/vimalkrml/fluxgrid-css/issues"
  },
  "author": "Vimal KR",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
